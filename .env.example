# ==============================================================================
# AutomationEdge Agentic Support — Environment Variables Template
# Copy this file to .env and fill in your values.
# ==============================================================================

# ──────────────────────────────────────────────────────────────────────────────
# T4 AutomationEdge Configuration
# ──────────────────────────────────────────────────────────────────────────────

T4_BASE_URL=https://t4.automationedge.com/aeengine/rest
T4_USERNAME=your-username@domain.com
T4_PASSWORD=your-password
T4_ORG_CODE=your-org-code
T4_TIMEOUT_SECONDS=30

# ── AE MCP Server (derived from T4 settings above) ──
AE_BASE_URL=https://t4.automationedge.com
AE_REST_BASE_PATH=/aeengine/rest
AE_USERNAME=your-username@domain.com
AE_PASSWORD=your-password
AE_ORG_CODE=your-org-code
AE_TIMEOUT_SECONDS=30
AE_VERIFY_SSL=false

# Optional JSON object for remote MCP auth/proxy headers, e.g. {"Authorization":"Bearer ..."}.
# AE_MCP_SERVER_HEADERS_JSON=
AE_MCP_SERVER_TIMEOUT_SECONDS=30
AE_TIMEOUT_SECONDS=30


# ── Google Cloud / Vertex AI ──
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/service-account-key.json
VERTEX_AI_MODEL=gemini-2.5-flash

# ── PostgreSQL + pgvector ──
POSTGRES_DSN=postgresql://user:password@localhost:5432/ops_agent

# ── Embeddings (Vertex AI text-embedding model) ──
EMBEDDING_MODEL=text-embedding-004

# ── Tool Gateway (REST tool calling endpoint) ──
TOOL_BASE_URL=http://127.0.0.1:9999
TOOL_AUTH_TOKEN=your-tool-auth-token

# ── Agent Behaviour ──
MAX_AGENT_ITERATIONS=15
MAX_RESTARTS_PER_WORKFLOW=3
MAX_BULK_OPERATIONS=10
STALE_ISSUE_MINUTES=30
RECURRENCE_ESCALATION_THRESHOLD=3

# ── Tool Selection ──
# Max RAG-matched tools sent to LLM per turn (rest available via discover_tools)
MAX_RAG_TOOLS=12

# ── Protected Workflows (comma-separated, never auto-restarted) ──
PROTECTED_WORKFLOWS=regulatory_report_irdai

# ── Logging ──
LOG_DIR=logs
LOG_LEVEL=INFO
# Set to true to show error type/message in chat when something fails (for debugging)
# SHOW_ERROR_HINT=false

# ── Extension Mode ──
# Set to "true" to use the full agentic orchestrator (LLM + RAG + tools)
# Set to "false" to use the deterministic plan-execute mode
USE_AGENTIC_MODE=true

# Agent Startup Path (for restart_ae_agent tool)
AGENT_STARTUP_PATH=C:\path\to\ae-agent\bin

AE_MCP_TOOLS_ENABLED=true
AE_MCP_SERVER_URL=http://127.0.0.1:3000/mcp/
AE_MCP_SERVER_TRANSPORT=streamable-http

# ── Cognibot / AI Studio configuration ──
COGNIBOT_BASE_URL=http://localhost:3978
COGNIBOT_DIRECTLINE_SECRET=your-directline-secret
