# ==============================================================================
# AutomationEdge Agentic Support — Environment Variables
# Copy this file to .env and fill in your values.
# ==============================================================================

# ── AutomationEdge API ──
AE_BASE_URL=https://your-ae-server:8443
AE_API_KEY=your-ae-service-account-api-key
AE_USERNAME=your-ae-username
AE_PASSWORD=your-ae-password
AE_ORG_CODE=your-org-code
AE_DEFAULT_USERID=ops_agent
AE_REST_BASE_PATH=/aeengine/rest
AE_AUTH_ENDPOINT=/authenticate
AE_EXECUTE_ENDPOINT=/execute
AE_WORKFLOWS_ENDPOINT=/workflows
AE_WORKFLOWS_METHOD=GET
AE_WORKFLOW_DETAILS_ENDPOINT=/workflows/{workflow_identifier}
AE_WORKFLOW_DETAILS_METHOD=GET
AE_SESSION_HEADER=X-session-token
AE_TOKEN_FIELD=token
AE_TOKEN_TTL_SECONDS=1800
AE_ENABLE_DYNAMIC_TOOLS=true
# Enable MCP tools in the main app. If AE_MCP_SERVER_URL is blank, the app imports the
# local mcp_server Python package. If AE_MCP_SERVER_URL is set, the app connects to that
# MCP endpoint over the network and discovers/tools calls remotely.
AE_MCP_TOOLS_ENABLED=false
AE_MCP_SERVER_URL=
AE_MCP_SERVER_TRANSPORT=streamable-http
# Optional JSON object for remote MCP auth/proxy headers, e.g. {"Authorization":"Bearer ..."}.
AE_MCP_SERVER_HEADERS_JSON=
AE_MCP_SERVER_TIMEOUT_SECONDS=30
AE_TIMEOUT_SECONDS=30

# ── Google Cloud / Vertex AI ──
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
VERTEX_AI_MODEL=gemini-2.0-flash

# ── PostgreSQL + pgvector ──
POSTGRES_DSN=postgresql://user:password@db-host:5432/ops_agent

# ── Embeddings (Vertex AI text-embedding model) ──
EMBEDDING_MODEL=text-embedding-004
# Optional: set to avoid cold-start embedding probe (e.g. 768 for text-embedding-004)
# EMBEDDING_DIMENSION=768

# ── Tool Gateway (REST tool calling endpoint) ──
TOOL_BASE_URL=http://localhost:9999
TOOL_AUTH_TOKEN=your-tool-auth-token

# ── Agent Behaviour ──
MAX_AGENT_ITERATIONS=15
MAX_RESTARTS_PER_WORKFLOW=3
MAX_BULK_OPERATIONS=10
STALE_ISSUE_MINUTES=30
RECURRENCE_ESCALATION_THRESHOLD=3

# ── Tool Selection ──
# Max RAG-matched tools sent to LLM per turn (rest available via discover_tools)
MAX_RAG_TOOLS=12

# ── Protected Workflows (comma-separated, never auto-restarted) ──
PROTECTED_WORKFLOWS=regulatory_report_irdai

# ── Logging ──
LOG_DIR=logs
LOG_LEVEL=INFO
# Set to true to show error type/message in chat when something fails (for debugging)
# SHOW_ERROR_HINT=false

# Agent catalog / interactions
AGENT_CATALOG_PATH=state/agent_catalog.json
AGENT_ADMIN_TOKEN=
AGENT_INTERACTION_LOG_LIMIT=500

# Optional aliases (if you keep T4-style variable names)
# T4_BASE_URL=https://t4.automationedge.com/aeengine/rest
# T4_USERNAME=your-username
# T4_PASSWORD=your-password
# T4_ORG_CODE=your-org-code
# T4_TIMEOUT_SECONDS=30

# ── Extension Mode ──
# Set to "true" to use the full agentic orchestrator (LLM + RAG + tools)
# Set to "false" to use the deterministic plan-execute mode
USE_AGENTIC_MODE=true
